# JotaCode - Netflix Code Monitor
# Configuración de entorno

# Base de datos SQLite
DATABASE_URL=file:./db/custom.db

# Credenciales IMAP (Hotmail/Outlook)
# Genera una contraseña de aplicación en: https://account.live.com/proofs/AppPassword
IMAP_USER=tu_correo@hotmail.com
IMAP_PASS=tu_contraseña_de_aplicacion

# PIN de acceso a la web (4+ dígitos)
APP_PIN=1234
